# ========================================
# OVERLEAF INSTANCE CONFIGURATION
# ========================================
# URL of your Overleaf instance (include protocol - http or https)
OL_INSTANCE=https://tools.lu.umu.se

# Admin credentials for managing user registrations
OL_ADMIN_EMAIL=it@tekniskfysik.se
# WARNING: Keep this password secure and never commit to version control
OL_ADMIN_PASSWORD=password

# ========================================
# ACCESS CONTROL SETTINGS
# ========================================
# IP filtering controls whether access is restricted to specific networks
# Set to false during development or when IP restrictions aren't needed
IP_FILTER=true

# Enable detailed logging for IP checking (useful for troubleshooting)
DEBUG_IP=false

# Comma-separated list of allowed network ranges in CIDR notation
# Example: university networks, local development networks, etc.
ALLOWED_NETWORKS=130.239.0.0/16,2001:6b0:e::/48,2001:6b0:f::/48,127.0.0.0/8,::1/128,172.0.0.0/8,192.168.0.0/16

# Comma-separated list of allowed email domains for registration
# Only users with these email domains can register
ALLOWED_DOMAINS=student.umu.se,umu.se

# ========================================
# VERIFICATION QUESTION (OPTIONAL)
# ========================================
# Adds an additional knowledge-based verification step
# Uncomment and set both values to enable verification

# Question displayed on the registration form
# VERIFICATION_QUESTION=What structure stands between lärarhuset and the university lake?

# Expected answer (case-insensitive)
# VERIFICATION_KEY=norrskenet

# If both VERIFICATION_QUESTION and VERIFICATION_KEY are left empty or commented,
# the verification step will be skipped

